<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- HEADER -->
    <TextView
        android:id="@+id/tvHeaderCarrito"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:padding="24dp"
        android:text="Tu Carrito"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="serif" />
        
    <View
        android:id="@+id/dividerHeader"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/tvHeaderCarrito"
        android:background="#E0E0E0" />

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/emptyStateCarrito"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/dividerHeader"
        android:layout_above="@id/bottomNavF"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_bag_outline"
            app:tint="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Tu carrito está vacío"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="¡Explora nuestras marcas y\nencuentra algo que te encante!"
            android:textColor="#888888"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnEmptyComprar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#000000"
            android:text="Empezar a comprar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- FILLED STATE -->
    <RelativeLayout
        android:id="@+id/filledStateCarrito"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/dividerHeader"
        android:layout_above="@id/bottomNavF"
        android:visibility="visible">

        <!-- Lista de Productos -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCarrito"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/layoutCheckoutParams"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp" />

        <!-- Checkout Bottom Bar -->
        <LinearLayout
            android:id="@+id/layoutCheckoutParams"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="#FFFFFF"
            android:elevation="16dp"
            android:orientation="vertical"
            android:padding="24dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total General"
                    android:textColor="#777777"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/tvTotalGeneral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="0.00 €"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:textSize="20sp" />
            </RelativeLayout>

            <Button
                android:id="@+id/btnCheckout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#000000"
                android:text="Tramitar Pedido"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </RelativeLayout>

    <include
        android:id="@+id/bottomNavF"
        layout="@layout/layout_bottom_nav" />

</RelativeLayout>
