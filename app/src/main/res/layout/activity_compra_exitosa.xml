<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FFFFFF"
    android:paddingHorizontal="32dp">

    <!-- Black circle with white checkmark -->
    <FrameLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginBottom="32dp">

        <View
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_round_black" />

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_circle"
            app:tint="#FFFFFF"
            android:padding="4dp" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Compra Realizada!"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold|italic"
        android:fontFamily="serif"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tu pedido ha sido procesado con éxito.\nRecibirás un email de confirmación muy pronto."
        android:textColor="#888888"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="40dp" />

    <!-- VER MIS PEDIDOS -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnVerPedidos"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="VER MIS PEDIDOS"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:background="@drawable/bg_button_black"
        android:layout_marginBottom="12dp" />

    <!-- VOLVER AL INICIO -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnVolverInicio"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="VOLVER AL INICIO"
        android:textColor="#000000"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:background="@drawable/bg_selectable_unselected" />

</LinearLayout>
