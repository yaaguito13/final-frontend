<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBarF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_selectable_unselected"
            android:src="@drawable/ic_arrow_back"
            android:padding="12dp"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/btnBack"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:text="Favoritos"
            android:textSize="28sp"
            android:textStyle="bold|italic"
            android:fontFamily="serif"
            android:textColor="#000000" />

        <ImageView
            android:id="@+id/ivCart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_button_black"
            android:src="@drawable/ic_bag_outline"
            android:padding="10dp"
            app:tint="#FFFFFF" />
    </RelativeLayout>

    <View
        android:id="@+id/div1"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_below="@id/topBarF"
        android:background="#000000"/>

    <!-- Toggle Buttons -->
    <LinearLayout
        android:id="@+id/toggleContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_below="@id/div1"
        android:layout_margin="24dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_selectable_unselected"
        android:padding="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="PRODUCTOS"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_selectable_selected"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="MARCAS"
            android:textColor="#9E9E9E"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toggleContainer"
        android:layout_above="@id/div2">

        <!-- RecyclerView for items (Hidden initially) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFavoritos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"/>

        <!-- Empty State (Visible initially) -->
        <LinearLayout
            android:id="@+id/llEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Circular heart icon container -->
            <RelativeLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_selectable_unselected">
                
                <!-- If you have ic_heart, use it here, tint it grey -->
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_heart_outline"
                    app:tint="#CCCCCC" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AÚN NO TIENES PRODUCTOS FAVORITOS."
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </FrameLayout>

    <View
        android:id="@+id/div2"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_above="@id/bottomNavF"
        android:background="#000000"/>

    <!-- Bottom Navigation -->
    <include 
        android:id="@+id/bottomNavF"
        layout="@layout/layout_bottom_nav" />

</RelativeLayout>
