<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavF">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Banner -->
            <ImageView
                android:id="@+id/ivBanner"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_round_white"
                android:elevation="4dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="12dp" />

            <!-- Cart Button -->
            <ImageButton
                android:id="@+id/btnCart"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_margin="16dp"
                android:background="@drawable/bg_round_black"
                android:elevation="4dp"
                android:src="@drawable/ic_bag_outline"
                android:padding="12dp"
                app:tint="#FFFFFF" />

            <!-- Logo Container (Floating) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/logoContainer"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="190dp"
                android:layout_marginStart="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:scaleType="fitCenter" />
            </androidx.cardview.widget.CardView>

            <!-- Brand Info Content -->
            <LinearLayout
                android:id="@+id/llContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/logoContainer"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvBrandName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zara"
                        android:textSize="32sp"
                        android:textStyle="bold|italic"
                        android:fontFamily="serif"
                        android:textColor="#000000" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnFavorite"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_round_white"
                            android:src="@drawable/ic_heart_outline"
                            android:padding="10dp"
                            android:elevation="2dp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_pill_black"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp"
                            android:text="4.5"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Moda rápida y tendencias globales."
                    android:textColor="#777777"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp" />

                <!-- Filters Row -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <Button
                            android:id="@+id/btnFilterAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TODOS"
                            android:backgroundTint="#000000"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/btnFilterPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Precio"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:textColor="#000000"
                            app:strokeColor="#DDDDDD"
                            android:layout_marginEnd="8dp"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/btnFilterSize"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Talla"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:textColor="#000000"
                            app:strokeColor="#DDDDDD"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Product List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBrandProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2" />

            </LinearLayout>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottomNavF"
        layout="@layout/layout_bottom_nav" />

</RelativeLayout>
