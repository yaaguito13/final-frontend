<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="40dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Simulación de Pago"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/btnCerrarPago"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textColor="#000000"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <!-- Total -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TOTAL A PAGAR"
        android:textColor="#AAAAAA"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvTotalPago"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.00 €"
        android:textColor="#000000"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginBottom="28dp" />

    <!-- VISA option -->
    <LinearLayout
        android:id="@+id/llVisa"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_card_border"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="48dp"
            android:layout_height="28dp"
            android:text="VISA"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_button_black" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•••• •••• •••• 4242"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expira 12/26"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivVisaCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_check_circle" />
    </LinearLayout>

    <!-- PayPal option -->
    <LinearLayout
        android:id="@+id/llPaypal"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_selectable_unselected"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="28dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="56dp"
            android:layout_height="28dp"
            android:text="PayPal"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#0079C1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="yago@example.com"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginStart="12dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <ImageView
            android:id="@+id/ivPaypalCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_check_circle"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Pay button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnPagarAhora"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Pagar Ahora"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_black" />

</LinearLayout>
