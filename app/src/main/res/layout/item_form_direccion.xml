<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="24dp"
    android:background="@drawable/bg_card_border"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nueva Dirección"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        android:fontFamily="serif"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ETIQUETA (EJ. CASA, OFICINA)"
        android:textColor="#AAAAAA"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etFormEtiqueta"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_selectable_unselected"
        android:hint="Ej. Casa de mis padres"
        android:textColorHint="#CCCCCC"
        android:textColor="#000000"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="20dp"
        android:inputType="textCapSentences" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DIRECCIÓN COMPLETA"
        android:textColor="#AAAAAA"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etFormDireccion"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_selectable_unselected"
        android:hint="Calle, número, piso, ciudad."
        android:textColorHint="#CCCCCC"
        android:textColor="#000000"
        android:textSize="14sp"
        android:padding="16dp"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFormCancelar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="CANCELAR"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_selectable_unselected"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFormGuardar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="GUARDAR"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_button_black"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
