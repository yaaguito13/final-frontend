<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="24dp"
    android:background="@drawable/bg_card_border"
    android:orientation="vertical"
    android:padding="20dp"
    android:clipChildren="false">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvPedidoId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pedido #..."
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold|italic"
                android:fontFamily="serif" />
            <TextView
                android:id="@+id/tvPedidoFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPedidoEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="..."
            android:textColor="#0000FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@drawable/bg_icon_border" />
    </RelativeLayout>

    <View
        android:id="@+id/vDividerTop"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp" />

    <!-- Expansible items container -->
    <LinearLayout
        android:id="@+id/llArticulosContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <View
        android:id="@+id/vDividerBottom"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="20dp"
        android:visibility="gone" />

    <!-- Footer -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvToggleDetalles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="VER DETALLES  >"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="vertical"
            android:gravity="end">
            <TextView
                android:id="@+id/tvTotalArticulos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ARTÍCULOS"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tvPedidoTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 €"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </RelativeLayout>

</LinearLayout>
